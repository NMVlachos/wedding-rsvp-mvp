# Copy this file to .env and fill in values before running locally or in production.
# .env is gitignored — never commit real secrets.

# Required: sign/verify JWTs. Use a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-in-production

# Backend server port
PORT=3001

# Path to the SQLite database file (relative paths resolved from backend/)
DB_PATH=./data/rsvp.db

# Origin allowed by CORS (set to your frontend URL)
CORS_ORIGIN=http://localhost:5173
